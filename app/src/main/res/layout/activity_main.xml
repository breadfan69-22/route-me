<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neumorph_surface"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimaryContainer"
        android:minHeight="?attr/actionBarSize"
        app:popupTheme="@style/ThemeOverlay.RouteMe.PopupMenu"
        app:title="@string/app_name"
        app:titleTextColor="?attr/colorOnPrimaryContainer" />

    <!-- ═══════════ DASHBOARD HERO (1/3 screen) ═══════════ -->
    <FrameLayout
        android:id="@+id/dashboardHero"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Gradient background -->
        <ImageView
            android:id="@+id/heroBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/bg_hero_gradient"
            android:scaleType="fitXY"
            android:importantForAccessibility="no" />

        <!-- Current client name (bottom of hero, above metric chips, visible when stopped at a client) -->
        <TextView
            android:id="@+id/heroClientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="48dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_metric_chip"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:maxWidth="280dp"
            android:visibility="gone" />

        <!-- Weather block (top-left, large icon + small temp) -->
        <LinearLayout
            android:id="@+id/heroWeatherChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/heroWeatherIcon"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/heroWeatherTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Right-justified countdown row (top-right) -->
        <LinearLayout
            android:id="@+id/heroCountdownRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="10dp"
            android:paddingEnd="12dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/heroCountdownPrefix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_metric_chip"
                android:paddingStart="6dp"
                android:paddingTop="3dp"
                android:paddingEnd="6dp"
                android:paddingBottom="3dp"
                android:text="@string/hero_stops_remaining_prefix"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/heroSplitFlapContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal" />

        </LinearLayout>

        <!-- Large centered equipment icon -->
        <ImageView
            android:id="@+id/heroIcon"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_hero_default"
            android:contentDescription="@string/hero_icon_desc" />

        <ImageView
            android:id="@+id/heroIconSecondary"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_hero_default"
            android:contentDescription="@string/hero_icon_desc"
            android:visibility="gone" />

        <!-- Dark mode overlay (GONE in light mode) -->
        <View
            android:id="@+id/heroDarkOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80000000"
            android:visibility="gone" />

        <!-- Bottom scrim gradient -->
        <View
            android:id="@+id/heroScrim"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_hero_scrim" />

        <!-- Metric chip row (over scrim, at bottom) -->
        <LinearLayout
            android:id="@+id/heroMetrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <!-- Step label chip -->
            <LinearLayout
                android:id="@+id/heroStepChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_metric_chip"
                android:layout_marginStart="6dp"
                android:visibility="gone">
                <ImageView
                    android:id="@+id/heroStepIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:importantForAccessibility="no" />
                <TextView
                    android:id="@+id/heroStepLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Destination chip -->
            <LinearLayout
                android:id="@+id/heroDestChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_metric_chip"
                android:layout_marginStart="6dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/heroDestText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:maxWidth="140dp" />
            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- ═══════════ OPERATIONAL TILES (2/3 screen, scrollable) ═══════════ -->
    <ScrollView
        android:id="@+id/tileScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/summaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <TextView
                android:id="@+id/errandsBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="?attr/colorTertiaryContainer"
                android:paddingStart="8dp"
                android:paddingTop="5dp"
                android:paddingEnd="8dp"
                android:paddingBottom="5dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnTertiaryContainer"
                android:visibility="gone" />

            <!-- Row 1: tracking + direction (most-used operational tiles) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipChildren="false"
                android:orientation="horizontal">

                <com.routeme.app.ui.NeumorphTileLayout
                    android:id="@+id/tileTracking"
                    android:layout_width="0dp"
                    android:layout_height="136dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/tile_tracking_title"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                            <ImageView
                                android:id="@+id/badgeTracking"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/tile_tracking_title"
                                android:padding="4dp"
                                android:src="@drawable/ic_more_horiz"
                                app:tint="?attr/colorPrimary" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/trackingButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/start_tracking"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.routeme.app.ui.NeumorphTileLayout>

                <com.routeme.app.ui.NeumorphTileLayout
                    android:id="@+id/tileDirection"
                    android:layout_width="0dp"
                    android:layout_height="136dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="2">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/tile_direction_title"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                            <ImageView
                                android:id="@+id/badgeDirection"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/tile_direction_title"
                                android:padding="4dp"
                                android:src="@drawable/ic_more_horiz"
                                app:tint="?attr/colorPrimary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:gravity="center">

                            <ImageView
                                android:id="@+id/directionIcon"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/tile_direction_icon"
                                android:src="@drawable/ic_arrow_upward"
                                app:tint="?attr/colorPrimary" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/directionText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tile_direction_default"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                        <TextView
                            android:id="@+id/destinationBanner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="?attr/colorSecondaryContainer"
                            android:paddingStart="8dp"
                            android:paddingTop="5dp"
                            android:paddingEnd="8dp"
                            android:paddingBottom="5dp"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/colorOnSecondaryContainer"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.routeme.app.ui.NeumorphTileLayout>
            </LinearLayout>

            <!-- Row 2: events, sync, current step -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipChildren="false"
                android:orientation="horizontal">

                <com.routeme.app.ui.NeumorphTileLayout
                    android:id="@+id/tileUpcoming"
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="3">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/tile_upcoming_title"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                            <ImageView
                                android:id="@+id/badgeUpcoming"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/tile_upcoming_title"
                                android:padding="4dp"
                                android:src="@drawable/ic_more_horiz"
                                app:tint="?attr/colorPrimary" />
                        </LinearLayout>
                    </LinearLayout>
                </com.routeme.app.ui.NeumorphTileLayout>

                <com.routeme.app.ui.NeumorphTileLayout
                    android:id="@+id/tileSync"
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="3">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/tile_sync_title"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                            <ImageView
                                android:id="@+id/badgeSync"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/tile_sync_title"
                                android:padding="4dp"
                                android:src="@drawable/ic_more_horiz"
                                app:tint="?attr/colorPrimary" />
                        </LinearLayout>
                    </LinearLayout>
                </com.routeme.app.ui.NeumorphTileLayout>

                <com.routeme.app.ui.NeumorphTileLayout
                    android:id="@+id/tileStep"
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="3">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tile_step_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                        <TextView
                            android:id="@+id/stepLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/tile_step_placeholder"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                    </LinearLayout>
                </com.routeme.app.ui.NeumorphTileLayout>
            </LinearLayout>

            <!-- Floating suggestion list — GONE when empty, appears when suggestions load -->
            <LinearLayout
                android:id="@+id/tileSuggested"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/suggestionHeader"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/tile_suggested_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                    <ImageView
                        android:id="@+id/badgeSuggestedRefresh"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/tile_refresh_suggestions"
                        android:padding="4dp"
                        android:src="@drawable/ic_refresh"
                        app:tint="?attr/colorPrimary" />
                </LinearLayout>

                <!-- Fixed height = ~5 slot rows visible; snap-scroll through the full list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/suggestionRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="240dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
