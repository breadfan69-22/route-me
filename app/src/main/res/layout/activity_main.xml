<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neumorph_surface"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimaryContainer"
        android:minHeight="?attr/actionBarSize"
        app:popupTheme="@style/ThemeOverlay.RouteMe.PopupMenu"
        app:title="@string/app_name"
        app:titleTextColor="?attr/colorOnPrimaryContainer" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/summaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <TextView
                android:id="@+id/errandsBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="?attr/colorTertiaryContainer"
                android:paddingStart="8dp"
                android:paddingTop="5dp"
                android:paddingEnd="8dp"
                android:paddingBottom="5dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnTertiaryContainer"
                android:visibility="gone" />

            <!-- Row 1: tracking + direction (most-used operational tiles) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipChildren="false"
                android:orientation="horizontal">

                <com.routeme.app.ui.NeumorphTileLayout
                    android:id="@+id/tileTracking"
                    android:layout_width="0dp"
                    android:layout_height="136dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/tile_tracking_title"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                            <ImageView
                                android:id="@+id/badgeTracking"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/tile_tracking_title"
                                android:padding="4dp"
                                android:src="@drawable/ic_more_horiz"
                                app:tint="?attr/colorPrimary" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/trackingButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/start_tracking"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.routeme.app.ui.NeumorphTileLayout>

                <com.routeme.app.ui.NeumorphTileLayout
                    android:id="@+id/tileDirection"
                    android:layout_width="0dp"
                    android:layout_height="136dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="2">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/directionIcon"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/tile_direction_icon"
                                android:src="@drawable/ic_arrow_upward"
                                app:tint="?attr/colorPrimary" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:text="@string/tile_direction_title"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                            <ImageView
                                android:id="@+id/badgeDirection"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/tile_direction_title"
                                android:padding="4dp"
                                android:src="@drawable/ic_more_horiz"
                                app:tint="?attr/colorPrimary" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/directionText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/tile_direction_default"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                        <TextView
                            android:id="@+id/destinationBanner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="?attr/colorSecondaryContainer"
                            android:paddingStart="8dp"
                            android:paddingTop="5dp"
                            android:paddingEnd="8dp"
                            android:paddingBottom="5dp"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/colorOnSecondaryContainer"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.routeme.app.ui.NeumorphTileLayout>
            </LinearLayout>

            <!-- Row 2: events, sync, current step -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipChildren="false"
                android:orientation="horizontal">

                <com.routeme.app.ui.NeumorphTileLayout
                    android:id="@+id/tileUpcoming"
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="3">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/tile_upcoming_title"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                            <ImageView
                                android:id="@+id/badgeUpcoming"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/tile_upcoming_title"
                                android:padding="4dp"
                                android:src="@drawable/ic_more_horiz"
                                app:tint="?attr/colorPrimary" />
                        </LinearLayout>
                    </LinearLayout>
                </com.routeme.app.ui.NeumorphTileLayout>

                <com.routeme.app.ui.NeumorphTileLayout
                    android:id="@+id/tileSync"
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="3">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/tile_sync_title"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                            <ImageView
                                android:id="@+id/badgeSync"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/tile_sync_title"
                                android:padding="4dp"
                                android:src="@drawable/ic_more_horiz"
                                app:tint="?attr/colorPrimary" />
                        </LinearLayout>
                    </LinearLayout>
                </com.routeme.app.ui.NeumorphTileLayout>

                <com.routeme.app.ui.NeumorphTileLayout
                    android:id="@+id/tileStep"
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="3">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tile_step_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                        <TextView
                            android:id="@+id/stepLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/tile_step_placeholder"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                    </LinearLayout>
                </com.routeme.app.ui.NeumorphTileLayout>
            </LinearLayout>

            <!-- Floating suggestion list — GONE when empty, appears when suggestions load -->
            <LinearLayout
                android:id="@+id/tileSuggested"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/suggestionHeader"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/tile_suggested_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                    <ImageView
                        android:id="@+id/badgeSuggestedRefresh"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/tile_refresh_suggestions"
                        android:padding="4dp"
                        android:src="@drawable/ic_refresh"
                        app:tint="?attr/colorPrimary" />
                </LinearLayout>

                <!-- Fixed height = ~5 slot rows visible; snap-scroll through the full list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/suggestionRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="240dp" />
            </LinearLayout>

            <com.routeme.app.ui.NeumorphTileLayout
                android:id="@+id/tileSelected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tile_selected_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                    <TextView
                        android:id="@+id/clientDetailsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/visitNotesLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:hint="@string/hint_visit_notes"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/visitNotesInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:maxLines="3"
                            android:textSize="13sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/mapsButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="2dp"
                            android:layout_weight="1"
                            android:text="Maps"
                            android:textSize="11sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/skipButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:layout_marginEnd="2dp"
                            android:layout_weight="1"
                            android:text="@string/btn_skip"
                            android:textSize="11sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/confirmButton"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:layout_weight="1"
                            android:text="Done"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/editNotesButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:text="@string/menu_edit_notes"
                            android:textSize="11sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/propertyButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:text="@string/tile_property"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/subtitleText"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:text="@string/mvp_subtitle"
                        android:visibility="gone" />
                </LinearLayout>
            </com.routeme.app.ui.NeumorphTileLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
